VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Gemini Flash — AI training session scoring (free tier: https://aistudio.google.com/app/apikey)
# Key is bundled in client — rotate or proxy via Cloud Function for production
VITE_GEMINI_API_KEY=

# Business 2FA (TOTP). Requires upgrading the Firebase project to Google Cloud
# Identity Platform (Authentication → enable MFA → TOTP). Set to "true" to expose
# the 2FA enrollment UI and the sign-in challenge. OAuth (Google/Microsoft) works
# without this. Also enable the Microsoft provider (Azure app registration) in the
# Firebase console for "Continue with Microsoft".
VITE_ENABLE_TOTP=
