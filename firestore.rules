rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // ─── Dog access helpers ───────────────────────────────────────────────────

    function isMainHuman(dogId) {
      return get(/databases/$(database)/documents/dogs/$(dogId)).data.mainHumanId == request.auth.uid;
    }
    function isApproved(dogId) {
      return exists(/databases/$(database)/documents/dogs/$(dogId)/humans/$(request.auth.uid));
    }
    function hasAccess(dogId) {
      return isMainHuman(dogId) || isApproved(dogId);
    }

    match /dogs/{dogId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null;
      allow update, delete: if isMainHuman(dogId);

      match /routines/{id}            { allow read, write: if hasAccess(dogId); }
      match /trainingSessions/{id}    { allow read, write: if hasAccess(dogId); }
      match /trainingTemplates/{id}   { allow read, write: if hasAccess(dogId); }
      match /medicalVaccinations/{id} { allow read, write: if hasAccess(dogId); }
      match /medicalMedications/{id}  { allow read, write: if hasAccess(dogId); }
      match /medicalFleaTick/{id}     { allow read, write: if hasAccess(dogId); }
      match /medicalDeworming/{id}    { allow read, write: if hasAccess(dogId); }
      match /medicalAllergies/{id}    { allow read, write: if hasAccess(dogId); }
      match /medicalDiagnoses/{id}    { allow read, write: if hasAccess(dogId); }
      match /medicalSurgeries/{id}    { allow read, write: if hasAccess(dogId); }
      match /humans/{humanId} {
        allow read:  if hasAccess(dogId) || request.auth.uid == humanId;
        allow write: if isMainHuman(dogId);
      }
      match /pendingHumans/{humanId} {
        allow read:   if isMainHuman(dogId) || request.auth.uid == humanId;
        allow create: if request.auth.uid == humanId;
        allow delete: if isMainHuman(dogId) || request.auth.uid == humanId;
      }
      match /devices/{id} { allow read, write: if hasAccess(dogId); }
    }

    // ─── Business CRM access helpers ──────────────────────────────────────────

    function bizStaff(bid) {
      return get(/databases/$(database)/documents/businesses/$(bid)/staff/$(request.auth.uid)).data;
    }
    function isBizMember(bid) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/businesses/$(bid)/staff/$(request.auth.uid));
    }
    function isBizOwner(bid) {
      return request.auth != null &&
        get(/databases/$(database)/documents/businesses/$(bid)).data.ownerUserId == request.auth.uid;
    }
    // Owner always passes; otherwise the active staff member must hold the cap
    // (capabilities are denormalized onto the staff doc for single-read checks).
    function hasCap(bid, cap) {
      return isBizOwner(bid) ||
        (isBizMember(bid) && bizStaff(bid).active == true && bizStaff(bid).capabilities.hasAny([cap]));
    }

    match /businesses/{bid} {
      allow read:   if isBizMember(bid);
      allow create: if request.auth != null && request.resource.data.ownerUserId == request.auth.uid;
      allow update: if hasCap(bid, 'manage_business');
      allow delete: if isBizOwner(bid);

      match /staff/{userId} {
        allow read:  if isBizMember(bid);
        // A user editing their OWN staff record must not change their capabilities
        // or role (prevents self-escalation); only the owner may edit the owner.
        allow create, delete: if hasCap(bid, 'manage_staff');
        allow update: if hasCap(bid, 'manage_staff') &&
          (request.auth.uid != userId ||
            (request.resource.data.capabilities == resource.data.capabilities &&
             request.resource.data.roleId == resource.data.roleId));
      }

      match /roles/{roleId} {
        allow read:  if isBizMember(bid);
        allow write: if hasCap(bid, 'manage_roles');
      }

      match /customers/{id} {
        allow read:  if hasCap(bid, 'view_customers') || hasCap(bid, 'manage_customers');
        allow write: if hasCap(bid, 'manage_customers');
      }

      match /pets/{id} {
        allow read:  if hasCap(bid, 'view_customers') || hasCap(bid, 'manage_customers');
        allow write: if hasCap(bid, 'manage_customers');
      }

      match /appointments/{id} {
        allow read:           if hasCap(bid, 'view_appointments') || hasCap(bid, 'manage_appointments');
        allow create, delete: if hasCap(bid, 'manage_appointments');
        allow update:         if hasCap(bid, 'manage_appointments') ||
          (hasCap(bid, 'manage_own_appointments') && resource.data.assignedStaffId == request.auth.uid);
      }

      match /invoices/{id} {
        allow read:           if hasCap(bid, 'view_invoices') || hasCap(bid, 'manage_invoices');
        allow create, delete: if hasCap(bid, 'manage_invoices');
        allow update:         if hasCap(bid, 'manage_invoices') || hasCap(bid, 'record_payments');
      }

      match /products/{id} {
        allow read:  if hasCap(bid, 'view_inventory') || hasCap(bid, 'manage_inventory');
        allow write: if hasCap(bid, 'manage_inventory');
      }

      match /shipments/{id} {
        allow read:  if hasCap(bid, 'view_shipments') || hasCap(bid, 'manage_shipments');
        allow write: if hasCap(bid, 'manage_shipments');
      }
    }

    match /publicDogCards/{dogId} {
      allow read:  if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/dogs/$(dogId)).data.mainHumanId == request.auth.uid;
    }
  }
}
