rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // ─── Dog access helpers ───────────────────────────────────────────────────

    function isMainHuman(dogId) {
      return get(/databases/$(database)/documents/dogs/$(dogId)).data.mainHumanId == request.auth.uid;
    }
    function isApproved(dogId) {
      return exists(/databases/$(database)/documents/dogs/$(dogId)/humans/$(request.auth.uid));
    }

    // ─── Org access helpers ───────────────────────────────────────────────────

    function orgData(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data;
    }
    function isOrgLeader(orgId) {
      return orgData(orgId).leaderUserIds.hasAny([request.auth.uid]);
    }
    function isOrgStaff(orgId) {
      return orgData(orgId).staffUserIds.hasAny([request.auth.uid]);
    }
    function isOrgMember(orgId) {
      return exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }
    function isEnrolledDogOwner(orgId, dogId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/enrolledDogs/$(dogId)).data.mainHumanId == request.auth.uid;
    }

    // ─── Dog-level access (includes org enrollment) ───────────────────────────

    function isOrgDog(dogId) {
      let orgId = get(/databases/$(database)/documents/dogs/$(dogId)).data.orgId;
      return orgId != null && isOrgMember(orgId);
    }
    function hasAccess(dogId) {
      return isMainHuman(dogId) || isApproved(dogId) || isOrgDog(dogId);
    }

    match /dogs/{dogId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null;
      allow update, delete: if isMainHuman(dogId);

      match /routines/{id}            { allow read, write: if hasAccess(dogId); }
      match /trainingSessions/{id}    { allow read, write: if hasAccess(dogId); }
      match /trainingTemplates/{id}   { allow read, write: if hasAccess(dogId); }
      match /medicalVaccinations/{id} { allow read, write: if hasAccess(dogId); }
      match /medicalMedications/{id}  { allow read, write: if hasAccess(dogId); }
      match /medicalFleaTick/{id}     { allow read, write: if hasAccess(dogId); }
      match /medicalDeworming/{id}    { allow read, write: if hasAccess(dogId); }
      match /medicalAllergies/{id}    { allow read, write: if hasAccess(dogId); }
      match /medicalDiagnoses/{id}    { allow read, write: if hasAccess(dogId); }
      match /medicalSurgeries/{id}    { allow read, write: if hasAccess(dogId); }
      match /humans/{humanId} {
        allow read:  if hasAccess(dogId) || request.auth.uid == humanId;
        allow write: if isMainHuman(dogId);
      }
      match /pendingHumans/{humanId} {
        allow read:   if isMainHuman(dogId) || request.auth.uid == humanId;
        allow create: if request.auth.uid == humanId;
        allow delete: if isMainHuman(dogId) || request.auth.uid == humanId;
      }
      match /devices/{id} { allow read, write: if hasAccess(dogId); }
    }

    // ─── Organizations ────────────────────────────────────────────────────────

    match /organizations/{orgId} {
      // Public read for discovery/search; only leaders can modify the org doc
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isOrgLeader(orgId);
      allow delete: if isOrgLeader(orgId);

      // Members subcollection — only leaders write, any member reads
      match /members/{userId} {
        allow read:  if isOrgLeader(orgId) || isOrgMember(orgId) || request.auth.uid == userId;
        allow write: if isOrgLeader(orgId);
      }

      // Pending join requests
      match /pendingMembers/{userId} {
        allow read:   if isOrgLeader(orgId) || request.auth.uid == userId;
        allow create: if request.auth.uid == userId;
        allow delete: if isOrgLeader(orgId) || request.auth.uid == userId;
      }

      // Enrolled dogs — leaders full access; staff read; dog owner reads their own
      match /enrolledDogs/{dogId} {
        allow read:   if isOrgLeader(orgId) || isOrgStaff(orgId) || isEnrolledDogOwner(orgId, dogId);
        allow create: if isOrgLeader(orgId);
        allow update: if isOrgLeader(orgId) || isOrgStaff(orgId);
        allow delete: if isOrgLeader(orgId);
      }

      // Tasks — leaders full access; assigned staff can update status; dog owner reads their dog's tasks
      match /tasks/{taskId} {
        allow read:   if isOrgLeader(orgId) || isOrgStaff(orgId);
        allow create: if isOrgLeader(orgId);
        allow update: if isOrgLeader(orgId) || (isOrgStaff(orgId) && resource.data.assignedTo == request.auth.uid);
        allow delete: if isOrgLeader(orgId);
      }

      // Daily report cards — any member writes; dog owner reads their dog's reports
      match /dailyReports/{reportId} {
        allow read:  if isOrgLeader(orgId) || isOrgStaff(orgId);
        allow write: if isOrgLeader(orgId) || isOrgStaff(orgId);
      }
    }

    match /publicDogCards/{dogId} {
      allow read:  if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/dogs/$(dogId)).data.mainHumanId == request.auth.uid;
    }
  }
}
