rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // ─── Dog access helpers ───────────────────────────────────────────────────

    function isMainHuman(dogId) {
      return get(/databases/$(database)/documents/dogs/$(dogId)).data.mainHumanId == request.auth.uid;
    }
    function isApproved(dogId) {
      return exists(/databases/$(database)/documents/dogs/$(dogId)/humans/$(request.auth.uid));
    }
    function hasAccess(dogId) {
      return isMainHuman(dogId) || isApproved(dogId);
    }

    match /dogs/{dogId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null;
      allow update, delete: if isMainHuman(dogId);

      match /routines/{id}            { allow read, write: if hasAccess(dogId); }
      match /trainingSessions/{id}    { allow read, write: if hasAccess(dogId); }
      match /trainingTemplates/{id}   { allow read, write: if hasAccess(dogId); }
      match /medicalVaccinations/{id} { allow read, write: if hasAccess(dogId); }
      match /medicalMedications/{id}  { allow read, write: if hasAccess(dogId); }
      match /medicalFleaTick/{id}     { allow read, write: if hasAccess(dogId); }
      match /medicalDeworming/{id}    { allow read, write: if hasAccess(dogId); }
      match /medicalAllergies/{id}    { allow read, write: if hasAccess(dogId); }
      match /medicalDiagnoses/{id}    { allow read, write: if hasAccess(dogId); }
      match /medicalSurgeries/{id}    { allow read, write: if hasAccess(dogId); }
      match /humans/{humanId} {
        allow read:  if hasAccess(dogId) || request.auth.uid == humanId;
        allow write: if isMainHuman(dogId);
      }
      match /pendingHumans/{humanId} {
        allow read:   if isMainHuman(dogId) || request.auth.uid == humanId;
        allow create: if request.auth.uid == humanId;
        allow delete: if isMainHuman(dogId) || request.auth.uid == humanId;
      }
      match /devices/{id} { allow read, write: if hasAccess(dogId); }
    }

    // ─── Business CRM access helpers ──────────────────────────────────────────

    function bizStaff(bid) {
      return get(/databases/$(database)/documents/businesses/$(bid)/staff/$(request.auth.uid)).data;
    }
    function isBizMember(bid) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/businesses/$(bid)/staff/$(request.auth.uid));
    }
    function isBizOwner(bid) {
      return request.auth != null &&
        get(/databases/$(database)/documents/businesses/$(bid)).data.ownerUserId == request.auth.uid;
    }
    // Owner always passes; otherwise the active staff member must hold the cap
    // (capabilities are denormalized onto the staff doc for single-read checks).
    function hasCap(bid, cap) {
      return isBizOwner(bid) ||
        (isBizMember(bid) && bizStaff(bid).active == true && bizStaff(bid).capabilities.hasAny([cap]));
    }
    // A business accepts customer self-bookings only when it is listed as bookable
    // in the public directory.
    function isBookable(bid) {
      return exists(/databases/$(database)/documents/businessDirectory/$(bid)) &&
        get(/databases/$(database)/documents/businessDirectory/$(bid)).data.bookable == true;
    }
    function directoryEntry(bid) {
      return get(/databases/$(database)/documents/businessDirectory/$(bid)).data;
    }
    // Customer self-writes are only accepted while the business has opted in via
    // its public directory entry. The `in` guards keep legacy entries (without
    // the newer fields) from erroring during evaluation.
    function acceptsOrders(bid) {
      return exists(/databases/$(database)/documents/businessDirectory/$(bid)) &&
        ('orderable' in directoryEntry(bid)) && directoryEntry(bid).orderable == true;
    }
    function acceptsStays(bid) {
      return exists(/databases/$(database)/documents/businessDirectory/$(bid)) &&
        ('boarding' in directoryEntry(bid)) && directoryEntry(bid).boarding.requestsOpen == true;
    }

    // Public, read-by-anyone business directory ("businesses near me"). Owners /
    // managers publish the denormalized projection; private business data stays
    // behind the /businesses rules below.
    match /businessDirectory/{bid} {
      allow read:  if true;
      allow create, delete: if isBizOwner(bid) || hasCap(bid, 'manage_business');
      // Staff publish the projection. Narrow field-scoped updates let the
      // relevant staff keep their slice fresh (busy slots, boarding fullDates),
      // and any signed-in user may refresh only the review aggregate
      // (best-effort, recomputed from /reviews by readers).
      allow update: if isBizOwner(bid) || hasCap(bid, 'manage_business') ||
        (hasCap(bid, 'manage_appointments') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['busySlots', 'updatedAt'])) ||
        (hasCap(bid, 'manage_boarding') &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['boarding', 'updatedAt'])) ||
        (request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['ratingAvg', 'ratingCount', 'updatedAt']));

      // Public product catalog projection. Inventory managers sync it on stock
      // changes; order managers refresh inStock after accept/restock.
      match /catalog/{pid} {
        allow read:  if true;
        allow write: if hasCap(bid, 'manage_inventory') || hasCap(bid, 'manage_orders')
                     || hasCap(bid, 'manage_business');
      }

      // Public adoptable-animal projection (shelters).
      match /adoptables/{id} {
        allow read:  if true;
        allow write: if hasCap(bid, 'manage_adoptions') || hasCap(bid, 'manage_business');
      }

      // Public group-class projection with spotsLeft (trainers). Enrolling
      // customers bump spotsLeft, so signed-in users may update that field only.
      match /classCatalog/{id} {
        allow read:   if true;
        allow create, delete: if hasCap(bid, 'manage_classes') || hasCap(bid, 'manage_business');
        allow update: if hasCap(bid, 'manage_classes') || hasCap(bid, 'manage_business') ||
          (request.auth != null &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['spotsLeft', 'updatedAt']));
      }

      // Public litter projection (breeders).
      match /litterCatalog/{id} {
        allow read:  if true;
        allow write: if hasCap(bid, 'manage_breeding') || hasCap(bid, 'manage_business');
      }

      // Reviews: one per user (doc id == reviewer uid), author-only writes.
      match /reviews/{uid} {
        allow read: if true;
        allow create, update: if request.auth != null && request.auth.uid == uid
          && request.resource.data.rating is number
          && request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /businesses/{bid} {
      allow read:   if isBizMember(bid);
      // The business model requires a logo, a registration/business ID and an
      // exact location (lat/lng) at creation.
      allow create: if request.auth != null
        && request.resource.data.ownerUserId == request.auth.uid
        && request.resource.data.registrationId is string && request.resource.data.registrationId.size() > 0
        && request.resource.data.logoURL is string && request.resource.data.logoURL.size() > 0
        && request.resource.data.location.lat is number
        && request.resource.data.location.lng is number;
      allow update: if hasCap(bid, 'manage_business');
      allow delete: if isBizOwner(bid);

      match /staff/{userId} {
        allow read:  if isBizMember(bid);
        // A user editing their OWN staff record must not change their capabilities
        // or role (prevents self-escalation); only the owner may edit the owner.
        allow create, delete: if hasCap(bid, 'manage_staff');
        allow update: if hasCap(bid, 'manage_staff') &&
          (request.auth.uid != userId ||
            (request.resource.data.capabilities == resource.data.capabilities &&
             request.resource.data.roleId == resource.data.roleId));
      }

      match /roles/{roleId} {
        allow read:  if isBizMember(bid);
        allow write: if hasCap(bid, 'manage_roles');
      }

      match /customers/{id} {
        allow read:  if hasCap(bid, 'view_customers') || hasCap(bid, 'manage_customers');
        allow write: if hasCap(bid, 'manage_customers');
      }

      match /pets/{id} {
        allow read:  if hasCap(bid, 'view_customers') || hasCap(bid, 'manage_customers');
        allow write: if hasCap(bid, 'manage_customers');
      }

      match /appointments/{id} {
        // Staff with the capability, or the customer the appointment is for.
        allow read: if hasCap(bid, 'view_appointments') || hasCap(bid, 'manage_appointments') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid);
        // Staff create, or a customer self-booking a constrained "scheduled" request.
        allow create: if hasCap(bid, 'manage_appointments') ||
          (request.auth != null
            && isBookable(bid)
            && request.resource.data.source == 'customer'
            && request.resource.data.customerUserId == request.auth.uid
            && request.resource.data.status == 'scheduled');
        allow delete: if hasCap(bid, 'manage_appointments');
        // Staff update; an assigned worker with manage_own_appointments; or the
        // customer changing only the status of their own booking (e.g. cancel).
        allow update: if hasCap(bid, 'manage_appointments') ||
          (hasCap(bid, 'manage_own_appointments') && resource.data.assignedStaffId == request.auth.uid) ||
          (resource.data.customerUserId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
      }

      match /invoices/{id} {
        allow read:           if hasCap(bid, 'view_invoices') || hasCap(bid, 'manage_invoices');
        allow create, delete: if hasCap(bid, 'manage_invoices');
        allow update:         if hasCap(bid, 'manage_invoices') || hasCap(bid, 'record_payments');
      }

      match /products/{id} {
        allow read: if hasCap(bid, 'view_inventory') || hasCap(bid, 'manage_inventory') ||
          hasCap(bid, 'view_orders') || hasCap(bid, 'manage_orders');
        allow create, delete: if hasCap(bid, 'manage_inventory');
        // Order acceptance / PO receiving may move stock without full inventory
        // rights — but only the stockQty field.
        allow update: if hasCap(bid, 'manage_inventory') ||
          ((hasCap(bid, 'manage_orders') || hasCap(bid, 'manage_purchasing')) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQty', 'updatedAt']));
      }

      match /shipments/{id} {
        allow read:  if hasCap(bid, 'view_shipments') || hasCap(bid, 'manage_shipments');
        allow write: if hasCap(bid, 'manage_shipments');
      }

      match /orders/{id} {
        // Staff with the capability, or the customer the order belongs to.
        allow read: if hasCap(bid, 'view_orders') || hasCap(bid, 'manage_orders') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid);
        // Staff create, or a customer placing a constrained unpaid order.
        allow create: if hasCap(bid, 'manage_orders') ||
          (request.auth != null
            && acceptsOrders(bid)
            && request.resource.data.source == 'customer'
            && request.resource.data.customerUserId == request.auth.uid
            && request.resource.data.status == 'placed'
            && request.resource.data.paymentStatus == 'unpaid');
        allow delete: if hasCap(bid, 'manage_orders');
        // Staff update, or the customer cancelling before acceptance (stock has
        // not moved yet, so no restock is owed).
        allow update: if hasCap(bid, 'manage_orders') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid
            && resource.data.status == 'placed'
            && request.resource.data.status == 'cancelled'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
      }

      match /stays/{id} {
        allow read: if hasCap(bid, 'view_boarding') || hasCap(bid, 'manage_boarding') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid);
        // Staff create, or a customer requesting a stay pending approval.
        allow create: if hasCap(bid, 'manage_boarding') ||
          (request.auth != null
            && acceptsStays(bid)
            && request.resource.data.source == 'customer'
            && request.resource.data.customerUserId == request.auth.uid
            && request.resource.data.status == 'requested');
        allow delete: if hasCap(bid, 'manage_boarding');
        allow update: if hasCap(bid, 'manage_boarding') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid
            && request.resource.data.status == 'cancelled'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
      }

      match /services/{id} {
        // The menu is harmless internally — any member may read it for forms.
        allow read:  if isBizMember(bid) || hasCap(bid, 'view_services');
        allow write: if hasCap(bid, 'manage_services');
      }

      match /shifts/{id} {
        // Everyone sees the rota they're part of; managers edit it.
        allow read:  if isBizMember(bid) || hasCap(bid, 'view_shifts');
        allow write: if hasCap(bid, 'manage_shifts');
      }

      match /timeOff/{id} {
        allow read: if isBizMember(bid) || hasCap(bid, 'view_shifts');
        // Staff file their own requests; managers decide them.
        allow create: if hasCap(bid, 'manage_shifts') ||
          (isBizMember(bid)
            && request.resource.data.staffUserId == request.auth.uid
            && request.resource.data.status == 'requested');
        allow update: if hasCap(bid, 'manage_shifts');
        allow delete: if hasCap(bid, 'manage_shifts') ||
          (isBizMember(bid) && resource.data.staffUserId == request.auth.uid
            && resource.data.status == 'requested');
      }

      match /suppliers/{id} {
        allow read:  if hasCap(bid, 'view_purchasing') || hasCap(bid, 'manage_purchasing');
        allow write: if hasCap(bid, 'manage_purchasing');
      }

      match /purchaseOrders/{id} {
        allow read:  if hasCap(bid, 'view_purchasing') || hasCap(bid, 'manage_purchasing');
        allow write: if hasCap(bid, 'manage_purchasing');
      }

      match /threads/{tid} {
        // Staff with messaging caps, or the customer whose thread this is.
        allow read: if hasCap(bid, 'view_messages') || hasCap(bid, 'manage_messages') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid);
        // Any active member may create/bump a thread — system messages ride on
        // order/stay transitions handled by non-messaging staff. Customers only
        // touch their own thread.
        allow create: if isBizMember(bid) ||
          (request.auth != null && request.resource.data.customerUserId == request.auth.uid);
        allow update: if isBizMember(bid) ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid);
        allow delete: if hasCap(bid, 'manage_messages');

        function threadOwner(bid, tid) {
          return get(/databases/$(database)/documents/businesses/$(bid)/threads/$(tid)).data.customerUserId;
        }
        match /messages/{mid} {
          allow read: if hasCap(bid, 'view_messages') || hasCap(bid, 'manage_messages') ||
            (request.auth != null && threadOwner(bid, tid) == request.auth.uid);
          allow create: if isBizMember(bid) ||
            (request.auth != null && threadOwner(bid, tid) == request.auth.uid);
          allow update, delete: if false; // messages are immutable
        }
      }

      match /reportCards/{id} {
        // Customers may read cards that were sent to them.
        allow read: if hasCap(bid, 'view_report_cards') || hasCap(bid, 'manage_report_cards') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid
            && resource.data.sentAt != null);
        allow write: if hasCap(bid, 'manage_report_cards');
      }

      match /packages/{id} {
        allow read:  if isBizMember(bid) || hasCap(bid, 'view_packages');
        allow write: if hasCap(bid, 'manage_packages');
      }

      match /customerPackages/{id} {
        allow read: if hasCap(bid, 'view_packages') || hasCap(bid, 'manage_packages') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid);
        // Staff sell, or a customer self-purchasing (record-only payment).
        allow create: if hasCap(bid, 'manage_packages') ||
          (request.auth != null
            && request.resource.data.customerUserId == request.auth.uid
            && request.resource.data.creditsRemaining == request.resource.data.creditsTotal);
        // Staff manage; customers redeem credits against their own package.
        allow update: if hasCap(bid, 'manage_packages') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['creditsRemaining', 'status', 'updatedAt'])
            && request.resource.data.creditsRemaining < resource.data.creditsRemaining);
        allow delete: if hasCap(bid, 'manage_packages');
      }

      match /adoptionListings/{id} {
        allow read:  if hasCap(bid, 'view_adoptions') || hasCap(bid, 'manage_adoptions');
        allow write: if hasCap(bid, 'manage_adoptions');
      }

      match /adoptionApplications/{id} {
        allow read: if hasCap(bid, 'view_adoptions') || hasCap(bid, 'manage_adoptions') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid);
        // Applicants apply themselves; staff review.
        allow create: if hasCap(bid, 'manage_adoptions') ||
          (request.auth != null
            && request.resource.data.customerUserId == request.auth.uid
            && request.resource.data.status == 'submitted');
        allow update, delete: if hasCap(bid, 'manage_adoptions');
      }

      match /chartEntries/{id} {
        allow read:  if hasCap(bid, 'view_patients') || hasCap(bid, 'manage_patients');
        allow write: if hasCap(bid, 'manage_patients');
      }

      match /classes/{id} {
        allow read:  if hasCap(bid, 'view_classes') || hasCap(bid, 'manage_classes');
        allow write: if hasCap(bid, 'manage_classes');
      }

      match /enrollments/{id} {
        allow read: if hasCap(bid, 'view_classes') || hasCap(bid, 'manage_classes') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid);
        // Customers enroll themselves (the class projection gates open classes);
        // staff enroll walk-ins.
        allow create: if hasCap(bid, 'manage_classes') ||
          (request.auth != null
            && request.resource.data.customerUserId == request.auth.uid
            && (request.resource.data.status == 'enrolled' || request.resource.data.status == 'waitlisted'));
        allow update: if hasCap(bid, 'manage_classes') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid
            && request.resource.data.status == 'cancelled'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
        allow delete: if hasCap(bid, 'manage_classes');
      }

      match /litters/{id} {
        allow read:  if hasCap(bid, 'view_breeding') || hasCap(bid, 'manage_breeding');
        allow write: if hasCap(bid, 'manage_breeding');
      }

      match /waitlist/{id} {
        allow read: if hasCap(bid, 'view_breeding') || hasCap(bid, 'manage_breeding') ||
          (request.auth != null && resource.data.customerUserId == request.auth.uid);
        // Customers join the waitlist themselves; staff manage it.
        allow create: if hasCap(bid, 'manage_breeding') ||
          (request.auth != null
            && request.resource.data.customerUserId == request.auth.uid
            && request.resource.data.status == 'waiting');
        allow update, delete: if hasCap(bid, 'manage_breeding');
      }
    }

    // Customers find their message threads across businesses with a single
    // collection-group query. Staff access goes through the scoped rule above.
    match /{path=**}/threads/{tid} {
      allow read: if request.auth != null && resource.data.customerUserId == request.auth.uid;
    }

    match /publicDogCards/{dogId} {
      allow read:  if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/dogs/$(dogId)).data.mainHumanId == request.auth.uid;
    }
  }
}
